# CowabungaAI Environment Configuration with Turso Support

# ============================================================================
# Database Configuration
# ============================================================================

# Database type: "supabase" or "turso"
DATABASE_TYPE=turso

# Turso Configuration (when DATABASE_TYPE=turso)
TURSO_DATABASE_PATH=/data/cowabunga.db
TURSO_URL=turso.cowabunga.svc.cluster.local:8080
TURSO_AUTH_TOKEN=your-turso-auth-token

# Supabase Configuration (when DATABASE_TYPE=supabase)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_KEY=your-service-key

# ============================================================================
# API Configuration
# ============================================================================

LEAPFROGAI_API_HOST=0.0.0.0
LEAPFROGAI_API_PORT=8080
LEAPFROGAI_API_WORKERS=4

# Backward compatibility (deprecated, use COWABUNGA_* instead)
COWABUNGA_API_HOST=${LEAPFROGAI_API_HOST}
COWABUNGA_API_PORT=${LEAPFROGAI_API_PORT}

# ============================================================================
# Model Configuration
# ============================================================================

DEFAULT_MODEL=synthia-7b
LLAMA_CPP_MODEL_PATH=/models/synthia-7b-v2.0.Q4_0.gguf
MAX_TOKENS=2048
TEMPERATURE=0.7

# ============================================================================
# Authentication
# ============================================================================

JWT_SECRET_KEY=your-secret-key-here
API_KEY_SALT=your-salt-here

# ============================================================================
# Logging
# ============================================================================

LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# Feature Flags
# ============================================================================

ENABLE_RAG=true
ENABLE_TRANSCRIPTION=false
ENABLE_FILE_UPLOADS=true

# ============================================================================
# Kubernetes/Deployment
# ============================================================================

POD_NAMESPACE=cowabunga
POD_NAME=cowabunga-api
